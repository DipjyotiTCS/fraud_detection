# Local Linux/GPU configuration for FraudSentinel LLM fine-tuning.
# Generated defaults. local_setup.sh will convert path values to absolute project paths.
# Do not commit this file to Git because it contains credentials.
export HF_TOKEN="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"
export FRAUD_ML_HOME="$(pwd)"
export VENV_DIR="$(pwd)/.venv"
export PYTHON_BIN="python3"
export INSTALL_GPU_TORCH="true"
export PYTORCH_CUDA_INDEX_URL="https://download.pytorch.org/whl/cu121"
export HOST="127.0.0.1"
export PORT="8000"
export RELOAD="true"
export HF_HUB_ENABLE_HF_TRANSFER="1"
export TOKENIZERS_PARALLELISM="false"
export LLM_DEFAULT_MODEL_ID="mistralai/Mistral-7B-Instruct-v0.3"
export LLM_DEFAULT_MODEL_REVISION="main"
export LLM_BASE_MODEL_DIR="$(pwd)/artifacts/llm/base"
export LLM_BASE_MODEL_PATH="$(pwd)/artifacts/llm/base/mistral-7b-instruct-v0.3"
export LLM_FINETUNED_MODEL_DIR="$(pwd)/artifacts/llm/finetuned"
export LLM_FINETUNED_OUTPUT_DIR="$(pwd)/artifacts/llm/finetuned/risk-report-mistral-7b"
export LLM_SFT_ADAPTER_DIR="$(pwd)/artifacts/llm/finetuned/risk-report-mistral-7b/sft/final_adapter"
export LLM_DPO_ADAPTER_DIR="$(pwd)/artifacts/llm/finetuned/risk-report-mistral-7b/dpo/final_adapter"
export LLM_FINAL_ADAPTER_DIR="$(pwd)/artifacts/llm/finetuned/risk-report-mistral-7b/dpo/final_adapter"
export LLM_SFT_DATASET_DIR="$(pwd)/data/llm/sft"
export LLM_DPO_DATASET_DIR="$(pwd)/data/llm/dpo"
export LLM_RUN_SFT="true"
export LLM_RUN_DPO="true"
export LLM_USE_4BIT="true"
export LLM_MAX_SEQ_LENGTH="2048"
export LLM_SFT_EPOCHS="2.0"
export LLM_DPO_EPOCHS="1.0"
export LLM_TRAIN_BATCH_SIZE="1"
export LLM_GRADIENT_ACCUMULATION_STEPS="8"
export LLM_LEARNING_RATE="0.0002"
export LLM_DPO_LEARNING_RATE="0.000005"
export LLM_LOGGING_STEPS="5"
export LLM_SAVE_STEPS="100"
export LLM_SAVE_TOTAL_LIMIT="2"
export LLM_SEED="42"
export LLM_LORA_R="16"
export LLM_LORA_ALPHA="32"
export LLM_LORA_DROPOUT="0.05"
export LLM_LORA_TARGET_MODULES="q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj"
export LLM_MAX_NEW_TOKENS="700"
export LLM_TEMPERATURE="0.2"
export LLM_TOP_P="0.9"
export LLM_ASYNC_MODE="true"
export LLM_VALIDATION_RATIO="0.1"
export LLM_TEST_RATIO="0.1"
